# ─── Sanity CMS Configuration ───────────────────────────────────────────────
# After you create a Sanity project (see the onboarding guide),
# replace the placeholder values below with your actual credentials.

# Your Sanity Project ID — a string like "abc123xy"
# You'll find this in your Sanity project dashboard
NEXT_PUBLIC_SANITY_PROJECT_ID=

# The name of your dataset — usually "production"
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version — this date format tells Sanity which API version to use
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
